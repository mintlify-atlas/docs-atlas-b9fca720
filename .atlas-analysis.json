  "keyFeatures": [
    "Offline documentation browsing with zero internet dependency",
    "Support for 200+ documentation sets (docsets) compatible with Dash",
    "Fast full-text search with fuzzy matching support",
    "Tabbed browsing interface for multiple documentation pages",
    "Global keyboard shortcuts for quick access",
    "Custom CSS styling for documentation appearance",
    "Dark mode support with automatic theme detection",
    "Protocol handlers for IDE integration (dash://, dash-plugin://)",
    "Built with Qt for cross-platform compatibility (Windows, Linux, macOS)"
  ],
  "publicApiSurface": [
    "Zeal::Core::Application - Main application controller",
    "Zeal::Core::Settings - Configuration management",
    "Zeal::Core::HttpServer - Local HTTP server for serving docs",
    "Zeal::Registry::Docset - Individual documentation set",
    "Zeal::Registry::DocsetRegistry - Docset collection manager",
    "Zeal::Registry::SearchQuery - Search query parser",
    "Zeal::Registry::SearchResult - Search result representation",
    "Zeal::Browser::WebView - Documentation viewer widget",
    "Zeal::Browser::WebPage - Custom web page with JS bridge",
    "Zeal::Browser::WebBridge - JavaScript-C++ communication bridge",
    "Zeal::WidgetUi::MainWindow - Main application window",
    "Zeal::WidgetUi::SettingsDialog - Settings configuration UI",
    "Zeal::WidgetUi::SearchSidebar - Search and navigation sidebar",
    "dash:// protocol - Direct search URL handler",
    "dash-plugin:// protocol - Plugin integration URL handler",
    "zeal <query> - Command-line search interface"
  ]
